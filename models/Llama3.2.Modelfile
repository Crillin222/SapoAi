# Modelfile para importar Llama 3.2 3B Instruct GGUF
# Uso: ollama create llama-3.2 -f ./models/Llama3.2.Modelfile

# Mude para o caminho real do arquivo .gguf baixado
FROM ./llama-3.2-3b-instruct-q4_k_m.gguf

# Parâmetros recomendados para 6GB VRAM
PARAMETER temperature 0.7
PARAMETER top_p 0.9
PARAMETER stop "<|start_header_id|>"
PARAMETER stop "<|end_header_id|>"
PARAMETER stop "<|eot_id|>"
PARAMETER num_ctx 4096

# Prompt de Sistema padrão para o Lab-AI Hub
SYSTEM """
Você é o assistente oficial do Lab-AI Hub, especializado em QA Automation, Robot Framework e XML proprietário.
Responda de forma técnica, concisa e focada em soluções offline.
"""
